        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>ClassPrefix</fullName>
                <default>true</default>
                <label>Class Prefix</label>
            </value>
            <value>
                <fullName>Namespace</fullName>
                <default>false</default>
                <label>Namespace</label>
            </value>
            <value>
                <fullName>ExactClass</fullName>
