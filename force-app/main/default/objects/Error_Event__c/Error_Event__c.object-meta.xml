<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Error Event</label>
    <pluralLabel>Error Events</pluralLabel>
    <description>Source-agnostic staging record for a single inbound runtime error notification (e.g. an Apex exception email). One row per occurrence; deduplicated to an Error Signature for diagnosis.</description>
    <deploymentStatus>Deployed</deploymentStatus>
    <sharingModel>ReadWrite</sharingModel>
    <enableSearch>true</enableSearch>
    <enableReports>true</enableReports>
    <enableHistory>true</enableHistory>
    <enableActivities>false</enableActivities>
    <nameField>
        <label>Error Event Number</label>
        <type>AutoNumber</type>
        <displayFormat>EVT-{000000}</displayFormat>
        <startingNumber>1</startingNumber>
    </nameField>
</CustomObject>
