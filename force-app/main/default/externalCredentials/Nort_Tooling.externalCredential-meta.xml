<?xml version="1.0" encoding="UTF-8"?>
<!--
  External Credential for same-org Tooling API access — OAuth 2.0 Client Credentials
  flow (with client secret), backed by an External Client App created in Setup
  (see docs/AGENT_SETUP.md).

  MANUAL POST-DEPLOY (cannot live in source):
   - AuthProviderUrl below is a placeholder; set it to this org's token endpoint
     (https://<MyDomain>.my.salesforce.com/services/oauth2/token).
   - The "NortToolingPrincipal" named principal's consumer key/secret (from the
     External Client App) are entered in Setup. Only after that does the principal
     become a referenceable ExternalCredentialPrincipal — that's why the permission
     set grants principal access as a manual step (see the permission set comment).

  The principal runs with the Nort_Error_Remediation permission set so callouts have
  the loop's metadata-read rights. Its parameterName must stay "NortToolingPrincipal"
  to match the permission set's externalCredentialPrincipal reference.
-->
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <authenticationProtocol>Oauth</authenticationProtocol>
    <externalCredentialParameters>
        <parameterGroup>DefaultGroup</parameterGroup>
        <parameterName>Oauth</parameterName>
        <parameterType>AuthProtocolVariant</parameterType>
        <parameterValue>ClientCredentialsClientSecret</parameterValue>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterGroup>DefaultGroup</parameterGroup>
        <parameterName>AuthProviderUrl</parameterName>
        <parameterType>AuthProviderUrl</parameterType>
        <parameterValue>https://example.my.salesforce.com/services/oauth2/token</parameterValue>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterGroup>NortToolingPrincipal</parameterGroup>
        <parameterName>NortToolingPrincipal</parameterName>
        <parameterType>NamedPrincipal</parameterType>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
    <label>Nort Tooling</label>
</ExternalCredential>
