<?xml version="1.0" encoding="UTF-8"?>
<!--
  External Credential for same-org Tooling API access.

  OAuth 2.0 Client Credentials flow, backed by an External Client App (created in
  Setup — see docs/AGENT_SETUP.md). The consumer key/secret and the named
  principal's auth are entered in Setup and are NOT in source. The named principal
  runs as a dedicated integration user holding the Nort_Error_Remediation
  permission set, so callouts have the same metadata-read rights the loop grants.

  VERIFY-AGAINST-ORG: the exact AuthProtocolVariant wiring for client-credentials
  may need finishing in Setup; this skeleton defines the reproducible structure.
-->
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <authenticationProtocol>OAuth</authenticationProtocol>
    <label>Nort Tooling</label>
    <externalCredentialParameters>
        <parameterName>ClientCredentials</parameterName>
        <parameterType>AuthProtocolVariant</parameterType>
        <parameterValue>ClientCredentials</parameterValue>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterName>NortToolingPrincipal</parameterName>
        <parameterType>NamedPrincipal</parameterType>
        <sequenceNumber>2</sequenceNumber>
    </externalCredentialParameters>
</ExternalCredential>
