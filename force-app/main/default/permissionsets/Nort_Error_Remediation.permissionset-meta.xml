<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Nort Error Remediation</label>
    <description>Access for nort's integration/agent running user: full access to the staging objects, Author Apex (so actions can read ApexClass.Body), and the automated-error Case record type. Assign to the user running the batch, queueables, and agent actions.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <objectPermissions>
        <object>Error_Event__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <modifyAllRecords>true</modifyAllRecords>
        <viewAllRecords>true</viewAllRecords>
        <viewAllFields>true</viewAllFields>
    </objectPermissions>
    <objectPermissions>
        <object>Error_Signature__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <modifyAllRecords>true</modifyAllRecords>
        <viewAllRecords>true</viewAllRecords>
        <viewAllFields>true</viewAllFields>
    </objectPermissions>
    <!-- Object grant uses viewAllFields (read-only); an explicit editable FLS
         entry is needed so permset holders can check the action checkbox. -->
    <fieldPermissions>
        <field>Error_Signature__c.Force_Reprocess__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <tabSettings>
        <tab>Error_Event__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Error_Signature__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <userPermissions>
        <enabled>true</enabled>
        <name>ApiEnabled</name>
    </userPermissions>
    <userPermissions>
        <enabled>true</enabled>
        <name>AuthorApex</name>
    </userPermissions>
    <!-- AuthorApex (needed so agent actions can read ApexClass.Body) requires
         these dependent permissions in Summer '26. -->
    <userPermissions>
        <enabled>true</enabled>
        <name>ModifyMetadata</name>
    </userPermissions>
    <userPermissions>
        <enabled>true</enabled>
        <name>ViewRoles</name>
    </userPermissions>
    <userPermissions>
        <enabled>true</enabled>
        <name>ViewSetup</name>
    </userPermissions>
    <recordTypeVisibilities>
        <recordType>Case.Nort_Automated_Error</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
    <classAccesses>
        <apexClass>NortConstants</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortConfig</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortFingerprint</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortEmailParser</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortIngestionService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortErrorEmailHandler</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortDedupBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortHeartbeatScheduler</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortAgentInvoker</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortDiagnosisQueueable</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortSignatureReprocessHandler</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortCaseService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortApexSourceAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortFlowMetadataAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortKnowledgeRetrievalAction</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortToolingClient</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>NortAnalysisGroundingProvider</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <!-- External Credential principal grant. MUST stay in source: permission-set
         deploys are NOT additive for this type, so any deploy that omits it WIPES
         the org's grant (re-granting it in Setup only lasts until the next deploy).
         The Nort_Tooling principal only becomes referenceable once its client secret
         is entered in Setup (the secret can't live in source), so a FRESH org cannot
         deploy this block until that one-time step is done — deploy the rest of the
         bundle first, configure the secret, then deploy this permission set.
         See docs/AGENT_SETUP.md (External/Named Credential setup). -->
    <externalCredentialPrincipalAccesses>
        <enabled>true</enabled>
        <externalCredentialPrincipal>Nort_Tooling-NortToolingPrincipal</externalCredentialPrincipal>
    </externalCredentialPrincipalAccesses>
</PermissionSet>
