<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Nort Error Remediation</label>
    <description>Access for the nort error remediation loop's integration/agent running user: full access to the staging objects, Author Apex so agent actions can read ApexClass.Body, and the automated-error Case record type. Assign to the user context that runs the batch, queueables, and agent actions.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <objectPermissions>
        <object>Error_Event__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <modifyAllRecords>true</modifyAllRecords>
        <viewAllRecords>true</viewAllRecords>
        <viewAllFields>true</viewAllFields>
    </objectPermissions>
    <objectPermissions>
        <object>Error_Signature__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <modifyAllRecords>true</modifyAllRecords>
        <viewAllRecords>true</viewAllRecords>
        <viewAllFields>true</viewAllFields>
    </objectPermissions>
    <userPermissions>
        <enabled>true</enabled>
        <name>ApiEnabled</name>
    </userPermissions>
    <userPermissions>
        <enabled>true</enabled>
        <name>AuthorApex</name>
    </userPermissions>
    <recordTypeVisibilities>
        <recordType>Case.Nort_Automated_Error</recordType>
        <visible>true</visible>
        <default>false</default>
    </recordTypeVisibilities>
    <classAccesses>
        <apexClass>NortConstants</apexClass>
