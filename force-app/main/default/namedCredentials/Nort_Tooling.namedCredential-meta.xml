<?xml version="1.0" encoding="UTF-8"?>
<!--
  Named Credential nort's Tooling client calls through:
    callout:Nort_Tooling/services/data/v66.0/tooling/...
  Its developer name must match NortConfig.toolingNamedCredential() (default
  'Nort_Tooling'). It points at the org's OWN My Domain and references the
  Nort_Tooling External Credential for client-credentials auth.

  VERIFY-AGAINST-ORG: replace the Url parameter value with this org's My Domain
  (https://<MyDomain>.my.salesforce.com) before go-live — it cannot live in source.
-->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
    <calloutStatus>Enabled</calloutStatus>
    <generateAuthorizationHeader>true</generateAuthorizationHeader>
    <label>Nort Tooling</label>
    <namedCredentialType>SecuredEndpoint</namedCredentialType>
    <namedCredentialParameters>
        <parameterName>Url</parameterName>
        <parameterType>Url</parameterType>
        <parameterValue>https://example.my.salesforce.com</parameterValue>
        <sequenceNumber>1</sequenceNumber>
    </namedCredentialParameters>
    <namedCredentialParameters>
        <parameterName>NortToolingCredential</parameterName>
        <parameterType>ExternalCredential</parameterType>
        <parameterValue>Nort_Tooling</parameterValue>
        <sequenceNumber>2</sequenceNumber>
    </namedCredentialParameters>
</NamedCredential>
